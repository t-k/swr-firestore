{
  "name": "@tatsuokaniwa/swr-firestore",
  "version": "3.1.0",
  "description": "React Hooks library for Firestore using SWR's subscription feature.",
  "keywords": [
    "firestore",
    "swr"
  ],
  "homepage": "https://github.com/t-k/swr-firestore#readme",
  "bugs": {
    "url": "https://github.com/t-k/swr-firestore/issues"
  },
  "license": "MIT",
  "author": "t-k (https://github.com/t-k)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t-k/swr-firestore.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./subscription": {
      "types": "./dist/subscription.d.ts",
      "import": "./dist/subscription.js",
      "require": "./dist/subscription.umd.cjs"
    },
    "./aggregate": {
      "types": "./dist/aggregate.d.ts",
      "import": "./dist/aggregate.js",
      "require": "./dist/aggregate.umd.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.umd.cjs"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && vite build && tsc --emitDeclarationOnly --declaration --rootDir src --outDir dist",
    "emulator": "firebase emulators:start --project swr-firestore-project --only firestore",
    "test": "vitest",
    "test:ci": "firebase emulators:exec --only auth,firestore,storage 'vitest run --coverage'",
    "coverage": "vitest run --coverage",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "firebase": ">=9.17.0",
    "firebase-admin": ">=11.5.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.57.0",
    "react": "^19",
    "react-dom": "^19",
    "swr": "^2.1.0 <3.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "firebase": ">=9.11.0",
    "firebase-admin": ">=11.0.0",
    "swr": "^2.1.0 <3.0.0"
  },
  "packageManager": "pnpm@10.19.0"
}
